# Docker Compose Configuration
FRONTEND_PORT=4173
APP_PORT=8080
DB_PORT=3306

# Frontend API - Update sesuai environment
# Development: http://localhost:8080
# Production: http://116.254.117.235:8080
VITE_URL_API=http://116.254.117.235:8080

# CORS Configuration - pastikan ini match dengan frontend URL
# Format: http://domain1:port,http://domain2:port
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://116.254.117.235:4173

# MySQL Configuration
MYSQL_DATABASE=jogojagad
MYSQL_USER=jogojagad
MYSQL_PASSWORD=jogojagad123
MYSQL_ROOT_PASSWORD=root123

# Laravel Configuration (from backend/.env)
APP_NAME=JogoJagad
APP_ENV=production
APP_DEBUG=false
APP_KEY=your-app-key-here
APP_URL=http://116.254.117.235:8080
